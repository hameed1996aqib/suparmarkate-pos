model Purchase {
  id String @id @default(cuid())

  invoiceNo  String?
  supplierId String?
  supplier   Party?  @relation(fields: [supplierId], references: [id])

  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id])

  status        PurchaseStatus        @default(COMPLETED)
  paymentStatus PurchasePaymentStatus @default(UNPAID)

  subtotal        Decimal @db.Decimal(18, 4)
  discount        Decimal @default(0) @db.Decimal(18, 4)
  total           Decimal @db.Decimal(18, 4)
  paidAmount      Decimal @default(0) @db.Decimal(18, 4)
  remainingAmount Decimal @default(0) @db.Decimal(18, 4)
  exchangeRate Decimal @default(1) @db.Decimal(18, 8)
  baseCurrencyId String?
  baseSubtotal Decimal @default(0) @db.Decimal(18, 4)
  baseTotal Decimal @default(0) @db.Decimal(18, 4)
  basePaidAmount Decimal @default(0) @db.Decimal(18, 4)
  baseRemainingAmount Decimal @default(0) @db.Decimal(18, 4)

  purchaseDate DateTime @default(now())
  note         String?
  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PurchaseItem[]
  returns PurchaseReturn[]

  @@index([supplierId])
  @@index([currencyId])
  @@index([invoiceNo])
  @@index([purchaseDate])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdByUserId])
  @@index([status, purchaseDate])
  @@index([currencyId, purchaseDate])
}

model PurchaseItem {
  id String @id @default(cuid())

  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  lotId String?
  lot   StockLot? @relation(fields: [lotId], references: [id])

  quantity       Decimal @db.Decimal(18, 4)
  conversionRate Decimal @db.Decimal(18, 4)
  quantityBase   Decimal @db.Decimal(18, 4)

  unitCost     Decimal @db.Decimal(18, 4)
  unitCostBase Decimal @db.Decimal(18, 4)
  totalCost    Decimal @db.Decimal(18, 4)

  expiryDate DateTime?

  createdAt DateTime @default(now())
  returnItems PurchaseReturnItem[]

  @@index([purchaseId])
  @@index([productId])
  @@index([warehouseId])
  @@index([unitId])
  @@index([lotId])
  @@index([expiryDate])
}

model PurchaseReturn {
  id String @id @default(cuid())

  returnNo String?
  purchaseId String
